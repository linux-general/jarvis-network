#cloud-config
# Jarvis Network cloud-init template.
# scripts/provision.sh substitutes ${VAR} placeholders before submitting to Vultr.
#
# Required substitutions:
#   PROFILE              brain | edge | nginx | seeder | voice-bridge
#   HOSTNAME             machine hostname (also the label)
#   HEADSCALE_AUTHKEY    one-shot Tailscale pre-auth key (90s TTL preferred)
#   JARVIS_NETWORK_REPO  e.g. https://github.com/linux-general/jarvis-network.git
#   VULTR_OS_HOSTNAME    e.g. atl2.vultrobjects.com
#   VULTR_OS_ACCESS_KEY  read-only scoped key for the configs bucket
#   VULTR_OS_SECRET_KEY  read-only scoped secret for the configs bucket
#   HF_TOKEN             HuggingFace read-only token (only used by seeder profile)

hostname: ${HOSTNAME}
manage_etc_hosts: true

# Authorized key for ws-47 jd, so we can SSH in over the public IP if
# Tailscale fails to join (cloud-init crashes happen — recoverable
# debugging requires inbound access). UFW rule allows port 22 only from
# Tailscale CGNAT by default, so this key only matters when run with a
# wider firewall (e.g. seeder profile temporarily opens port 22 to all).
ssh_authorized_keys:
  - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIBDd5DanPq4DUBjVUNVHQQXRt21LXHcptWfHJsa7vbXW jd@ws-47

package_update: true
package_upgrade: false
packages:
  - curl
  - jq
  - ca-certificates
  - gnupg
  - lsb-release
  - git
  - python3
  - python3-venv
  - python3-pip
  - ufw

write_files:
  - path: /etc/jarvis/profile
    permissions: '0644'
    content: |
      ${PROFILE}

  - path: /etc/jarvis/bootstrap.env
    permissions: '0600'
    content: |
      JARVIS_PROFILE=${PROFILE}
      JARVIS_HOSTNAME=${HOSTNAME}
      JARVIS_NETWORK_REPO=${JARVIS_NETWORK_REPO}
      VULTR_OS_HOSTNAME=${VULTR_OS_HOSTNAME}
      VULTR_OS_ACCESS_KEY=${VULTR_OS_ACCESS_KEY}
      VULTR_OS_SECRET_KEY=${VULTR_OS_SECRET_KEY}
      HF_TOKEN=${HF_TOKEN}

  - path: /etc/jarvis/headscale-authkey
    permissions: '0600'
    content: |
      ${HEADSCALE_AUTHKEY}

  - path: /opt/jarvis-network/scripts/write-seeder-marker.py
    permissions: '0755'
    content: |
      #!/usr/bin/env python3
      """Write the seeder completion marker to s3://jarvis-backups/seeder-markers/.
      Run by the seeder branch of runcmd after seed-models.py finishes.
      The status arg should be 'success' or 'failure'."""
      import json, os, socket, sys
      try:
          import boto3
      except ImportError:
          # seed-models.py builds the venv at ~/.venvs/jarvis-os; re-exec into it
          venv_py = os.path.expanduser("~/.venvs/jarvis-os/bin/python3")
          if os.path.exists(venv_py) and sys.executable != venv_py:
              os.execv(venv_py, [venv_py, *sys.argv])
          raise
      status = sys.argv[1] if len(sys.argv) > 1 else "unknown"
      s3 = boto3.client(
          "s3",
          endpoint_url=f"https://{os.environ['VULTR_OS_HOSTNAME']}",
          aws_access_key_id=os.environ["VULTR_OS_ACCESS_KEY"],
          aws_secret_access_key=os.environ["VULTR_OS_SECRET_KEY"],
          region_name="atl",
      )
      host = socket.gethostname()
      body = json.dumps({"host": host, "status": status,
                         "ts": int(__import__("time").time())}).encode()
      s3.put_object(Bucket="jarvis-backups",
                    Key=f"seeder-markers/{host}.json",
                    Body=body, ContentType="application/json")
      print(f"marker written: seeder-markers/{host}.json status={status}")

  - path: /etc/systemd/system/jarvis-hardware-tier.service
    permissions: '0644'
    content: |
      [Unit]
      Description=Detect GPU/CPU tier and write /run/jarvis/tier.json
      After=network-online.target

      [Service]
      Type=oneshot
      ExecStart=/opt/jarvis-network/scripts/detect-hardware-tier.sh

  - path: /etc/systemd/system/jarvis-hardware-tier.timer
    permissions: '0644'
    content: |
      [Unit]
      Description=Re-detect hardware tier every 30 min (catches GPU hot-add)

      [Timer]
      OnBootSec=10s
      OnUnitActiveSec=30min
      Persistent=true

      [Install]
      WantedBy=timers.target

runcmd:
  # ── 1. Docker ──────────────────────────────────────────────────────────────
  - |
    install -d -m 0755 /etc/apt/keyrings
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
    chmod a+r /etc/apt/keyrings/docker.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo $VERSION_CODENAME) stable" \
      | tee /etc/apt/sources.list.d/docker.list >/dev/null
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y -qq docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
    systemctl enable --now docker

  # ── 2. Tailscale + headscale join ──────────────────────────────────────────
  - curl -fsSL https://tailscale.com/install.sh | sh
  - |
    tailscale up \
      --login-server=https://headscale.jarvisnetwork.org \
      --authkey="$(cat /etc/jarvis/headscale-authkey)" \
      --hostname="${HOSTNAME}" \
      --accept-routes \
      --ssh
    shred -u /etc/jarvis/headscale-authkey

  # ── 3. UFW: open SSH only from tailnet ─────────────────────────────────────
  - ufw default deny incoming
  - ufw default allow outgoing
  - ufw allow from 100.64.0.0/10 to any port 22 proto tcp comment 'tailnet-ssh'
  - ufw allow from fd7a:115c:a1e0::/48 to any port 22 proto tcp comment 'tailnet-ssh-v6'
  - ufw --force enable

  # ── 4. Clone jarvis-network (idempotent — cloud-init may re-run on reboot) ─
  - |
    if [ -d /opt/jarvis-network/.git ]; then
      cd /opt/jarvis-network && git pull --rebase --quiet
    else
      rm -rf /opt/jarvis-network
      git clone --depth 1 ${JARVIS_NETWORK_REPO} /opt/jarvis-network
    fi
  - chmod +x /opt/jarvis-network/scripts/*.sh /opt/jarvis-network/scripts/*.py
  # boto3 system-wide so the marker writer runs even if seed-models.py
  # never created its venv (cascading-failure resilience).
  - pip install --break-system-packages --quiet boto3 || apt-get install -y python3-boto3 || true

  # ── 5. Hardware-tier detector (runs at boot + every 30 min) ────────────────
  - mkdir -p /run/jarvis
  - systemctl daemon-reload
  - systemctl enable --now jarvis-hardware-tier.timer
  - /opt/jarvis-network/scripts/detect-hardware-tier.sh

  # ── 6. Profile-specific bootstrap ──────────────────────────────────────────
  - |
    case "${PROFILE}" in
      brain)
        echo "TODO: brain profile (vllm + ollama + harness compose) — task #3"
        ;;
      edge)
        # Edge profile: CPU-only node that talks to cloud STT/TTS/LLM.
        # detect-hardware-tier.sh has already written /run/jarvis/tier.json;
        # if recommended_mode=cloud (no GPU detected), the llm-router will
        # boot in cloud-only mode automatically when brain.yml comes up.
        set -a; . /etc/jarvis/bootstrap.env; set +a

        # GHCR login (token must be in bootstrap.env as GHCR_PULL_TOKEN, or
        # the compose pull will fail for private images).
        if [ -n "${GHCR_PULL_TOKEN:-}" ]; then
          echo "$GHCR_PULL_TOKEN" | docker login ghcr.io -u linux-general --password-stdin
        fi

        # Pull a slim "edge" compose: just llm-router + voice-orchestrator +
        # cloud-backed STT/TTS containers. No vllm, no ollama, no caddy.
        # The compose file is fetched from c3po-ready; consumer config (cloud
        # API keys) comes from machine.env on first boot.
        mkdir -p /opt/c3po-ready
        cd /opt/c3po-ready
        git clone --depth 1 https://github.com/linux-general/c3po-ready.git . || true
        # TODO once c3po-ready/compose/edge-cloud.yml exists (#9 follow-up),
        # docker compose -f compose/edge-cloud.yml up -d. For now we leave
        # the node provisioned with images pulled and config ready, and the
        # operator brings the stack up manually.
        echo "edge node ready; bring up compose manually after configuring machine.env"
        ;;
      nginx)
        echo "TODO: nginx profile (reverse proxy + voice-bridge systemd unit) — task #10"
        ;;
      voice-bridge)
        echo "TODO: voice-bridge profile (Twilio websocket holder) — task #10"
        ;;
      seeder)
        # One-shot: source bucket creds + HF_TOKEN, mirror all current-status
        # models, signal completion via s3://jarvis-backups/seeder-markers/.
        # The marker is durable (no SSH/Tailscale dep) so provision.sh can
        # detect completion even if cloud-init breaks Tailscale.
        # Previously had inline heredoc here — bash heredoc terminator must
        # be at column 0 which is impossible inside indented YAML runcmd,
        # so the marker script is now write_files-staged.
        set -a; . /etc/jarvis/bootstrap.env; set +a
        export HF_HUB_ENABLE_HF_TRANSFER=1
        if /opt/jarvis-network/scripts/seed-models.py --all 2>&1 | tee /var/log/seed-models.log; then
          status="success"
        else
          status="failure"
        fi
        # Re-exec write-seeder-marker.py — it self-bootstraps into the venv
        # that seed-models.py created if boto3 isn't on the system Python.
        /opt/jarvis-network/scripts/write-seeder-marker.py "$status" \
          2>&1 | tee -a /var/log/seed-models.log
        touch /run/jarvis/seeder-done
        ;;
      *)
        echo "Unknown profile: ${PROFILE}" >&2
        ;;
    esac

  # ── 7. Mark cloud-init complete ────────────────────────────────────────────
  - touch /run/jarvis/cloud-init-done

final_message: "Jarvis Network cloud-init complete. Profile=${PROFILE} Tier=$(cat /run/jarvis/tier.json 2>/dev/null | jq -r .tier)"
